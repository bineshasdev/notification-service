NODE_ENV=development
PORT=3002

# PostgreSQL (notification service own DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_service_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=notif:

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notification-service
KAFKA_CLIENT_ID=notification-service
KAFKA_TOPIC_NOTIFICATIONS=platform.notifications
KAFKA_TOPIC_NOTIFICATION_EVENTS=platform.notification.events
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_TOPIC_EVENTS=platform.events

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:3000

# JWT / Keycloak (master realm)
JWKS_URI=http://localhost:9080/realms/master/protocol/openid-connect/certs
JWT_ISSUER=http://localhost:9080/realms/master

# Email (SMTP)
# For Gmail: use smtp.gmail.com:587 with a Gmail App Password
# Generate App Password: https://myaccount.google.com/apppasswords
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=you@gmail.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# FCM (Push)
FCM_SERVER_KEY=

# Retry config
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000
